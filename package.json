{
  "name": "slack-ticket",
  "version": "0.2.1",
  "description": "CLI tool to convert Slack threads into GitHub issues",
  "type": "module",
  "bin": {
    "slack-ticket": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "standardts \"src/**/*.ts\"",
    "lint:fix": "standardts \"src/**/*.ts\" --fix",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "pnpm run build",
    "prepare": "husky"
  },
  "keywords": [
    "slack",
    "github",
    "cli",
    "bug-report",
    "ticket"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/elvis-ndubuisi/slack-ticket.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "packageManager": "pnpm@10.8.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "inquirer": "^12.4.2",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^22.13.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "standardts": "^1.0.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.ts": "standardts --fix"
  }
}
