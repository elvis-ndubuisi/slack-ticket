{
  "name": "slack-ticket",
  "version": "0.1.0",
  "description": "CLI tool to convert Slack threads into GitHub issues",
  "type": "module",
  "bin": {
    "slack-ticket": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "slack",
    "github",
    "cli",
    "bug-report",
    "ticket"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.8.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "inquirer": "^12.4.2",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.1",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}